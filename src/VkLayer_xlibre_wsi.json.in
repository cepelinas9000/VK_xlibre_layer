{
    "file_format_version" : "1.0.0",
    "layer" : {
      "name": "VK_LAYER_xlibre_wsi",
      "type": "GLOBAL",
      "api_version": "1.4.321",
      "library_path": "@lib_dir@/libVkLayer_xlibre_wsi.so",
      "implementation_version": "1",
      "description": "WSI xlibre Layer (@family@)",
      "functions": {
         "vkNegotiateLoaderLayerInterfaceVersion": "vkNegotiateLoaderLayerInterfaceVersion"
      },
      "instance_extensions": [
        {
          "name": "VK_EXT_swapchain_colorspace",
          "spec_version": 5
        },
        { "name": "VK_KHR_xcb_surface",
          "spec_version": 6
        },
        { "name": "VK_KHR_xlib_surface",
          "spec_version": 6
        }
      ],

      "device_extensions": [
        {
          "name": "VK_EXT_hdr_metadata",
          "spec_version": 3
        }
      ],
      "enable_environment": {
        "ENABLE_XLIBRE_WSI": "1"
      },
      "disable_environment": {
        "DISABLE_XLIBRE_WSI": "1"
      }
    }
}
